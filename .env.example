# Railway provides DATABASE_URL automatically when you attach a Postgres plugin.
DATABASE_URL=postgresql://user:password@host:port/dbname

# Pick your own strong secret - this is your admin password for adding/removing products.
ADMIN_KEY=change-this-to-something-strong

# Your live Netlify URL, so the API only accepts requests from your site.
FRONTEND_URL=https://your-site.netlify.app

PORT=4000
