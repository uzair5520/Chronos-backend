# ── OAuth app credentials ───────────────────────────────────────
APP_ID=                   # Application ID (from wherever you registered OAuth)
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database (Railway MySQL plugin gives you this connection string) ──
DATABASE_URL=              # mysql://user:pass@host:port/db

# ── OAuth server URLs ────────────────────────────────────────────
KIMI_AUTH_URL=              # Kimi OAuth server URL
KIMI_OPEN_URL=              # Kimi Open Platform URL

# ── Admin role ────────────────────────────────────────────────────
OWNER_UNION_ID=             # Union ID of the app creator; this user becomes "admin" on first login

# ── Frontend location (Netlify site URL, no trailing slash) ───────
# Needed for CORS and to send the browser back to the right place after login.
FRONTEND_URL=https://your-site.netlify.app

# ── Server ─────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
